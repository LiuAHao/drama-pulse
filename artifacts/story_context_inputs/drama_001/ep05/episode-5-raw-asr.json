    {
      "text": "借什么都不能借粮食",
      "start_time": 12850,
      "end_time": 14470
    },
    {
      "text": "走走走走走走",
      "start_time": 14470,
      "end_time": 16510
    },
    {
      "text": "唉，王婶子",
      "start_time": 17220,
      "end_time": 18940
    },
    {
      "text": "你借我们家一点粮呗",
      "start_time": 19820,
      "end_time": 21220
