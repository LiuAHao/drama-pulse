      "end_time": 14840
    },
    {
      "text": "无可奉告",
      "start_time": 14920,
      "end_time": 15880
    },
    {
      "text": "让一让让让让让让",
      "start_time": 15880,
      "end_time": 17920
    },
    {
      "text": "我叫程中安",
