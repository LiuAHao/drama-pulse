      "end_time": 38640
    },
    {
      "text": "自然是",
      "start_time": 39640,
      "end_time": 40920
    },
    {
      "text": "啊啊啊！师座快冲",
      "start_time": 53980,
      "end_time": 57140
    },
    {
      "text": "快快快救救我",
      "start_time": 57260,
      "end_time": 59020
    },
    {
      "text": "赵留下难哦",
