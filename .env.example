# Shared
APP_ENV=local

# Server
PORT=8787
HOST=0.0.0.0
# Prisma schema 在 `server/prisma/` 下，所以这个默认值实际对应 `server/data/app.db`
DATABASE_URL=file:../data/app.db
ASSET_BASE_PATH=../assets
VIDEO_BASE_PATH=../videos

# AI
# Doubao / ARK
# 预留给后续分支生成链路；高光识别链路不再依赖这组配置。
ARK_API_KEY=
ARK_ENDPOINT=
ARK_MODEL=

# 图片生成
IMAGE_API_KEY=
IMAGE_BASE_URL=
IMAGE_MODEL=

# DeepSeek
# 高光 story context / stage-1 screening / review 默认都走 DEEPSEEK_MODEL，
# 如需分阶段切模型，可分别覆盖下面三个可选字段。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_HIGHLIGHT_CONTEXT_MODEL=
DEEPSEEK_HIGHLIGHT_DETECT_MODEL=
DEEPSEEK_HIGHLIGHT_REVIEW_MODEL=
DEEPSEEK_BRANCH_TASK_MODEL=

# BranchTask 调试开关
BRANCH_TASK_DISABLE_LLM=

XIAOMI_API_KEY=
XIAOMI_BASE_URL=
XIAOMI_MODEL=mimo-v2.5-tts

# Admin
ADMIN_PORT=3001
ADMIN_TOKEN=replace-me

# Android
ANDROID_API_BASE_URL=http://127.0.0.1:8787
