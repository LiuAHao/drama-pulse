# Shared
APP_ENV=local

# Server
PORT=8787
HOST=0.0.0.0
# Prisma schema 在 `server/prisma/` 下，所以这个默认值实际对应 `server/data/app.db`
DATABASE_URL=file:../data/app.db
ASSET_BASE_PATH=../assets
VIDEO_BASE_PATH=../videos

# AI
ARK_API_KEY=
ARK_ENDPOINT=
ARK_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

XIAOMI_API_KEY=
XIAOMI_BASE_URL=
XIAOMI_MODEL=mimo-v2.5-tts

# Admin
ADMIN_PORT=3001
ADMIN_TOKEN=replace-me

# Android
ANDROID_API_BASE_URL=http://127.0.0.1:8787
